# Cloudflare Pages headers — security + caching. Applied automatically on deploy.

# Note: X-Frame-Options is intentionally NOT set so the /embed/* calculator
# widgets can be embedded on other sites (a link-building feature). The site is
# stateless — no logins, cookies, or sessions — so clickjacking risk is minimal.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

# Fingerprinted assets can be cached forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
