---
import { SITE } from "../config.ts";
import { CALCULATORS } from "../lib/catalog.ts";
---

<header class="sticky top-0 z-40 border-b border-slate-200 bg-white/90 backdrop-blur">
  <nav class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
    <a href="/" class="flex items-center gap-2 font-extrabold text-slate-900">
      <span class="grid h-8 w-8 place-items-center rounded-lg bg-brand-600 text-white">$</span>
      <span class="text-lg">{SITE.name}</span>
    </a>

    <div class="hidden items-center gap-6 md:flex">
      <div class="group relative">
        <button class="flex items-center gap-1 font-medium text-slate-600 hover:text-slate-900">
          Calculators
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="invisible absolute left-1/2 z-50 mt-2 w-64 -translate-x-1/2 rounded-xl border border-slate-200 bg-white p-2 opacity-0 shadow-lg transition group-hover:visible group-hover:opacity-100">
          {CALCULATORS.map((c) => (
            <a href={`/calculators/${c.slug}`} class="block rounded-lg px-3 py-2 text-sm text-slate-700 hover:bg-slate-50">
              {c.short}
            </a>
          ))}
        </div>
      </div>
      <a href="/guides" class="font-medium text-slate-600 hover:text-slate-900">Guides</a>
      <a href="/about" class="font-medium text-slate-600 hover:text-slate-900">About</a>
      <a href="/calculators/compound-interest" class="btn">Try a calculator</a>
    </div>

    <details class="md:hidden">
      <summary class="list-none rounded-lg border border-slate-300 p-2 text-slate-700">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      </summary>
      <div class="absolute right-2 mt-2 w-56 rounded-xl border border-slate-200 bg-white p-2 shadow-lg">
        {CALCULATORS.map((c) => (
          <a href={`/calculators/${c.slug}`} class="block rounded-lg px-3 py-2 text-sm text-slate-700 hover:bg-slate-50">{c.short}</a>
        ))}
        <hr class="my-1 border-slate-100" />
        <a href="/guides" class="block rounded-lg px-3 py-2 text-sm text-slate-700 hover:bg-slate-50">Guides</a>
        <a href="/about" class="block rounded-lg px-3 py-2 text-sm text-slate-700 hover:bg-slate-50">About</a>
      </div>
    </details>
  </nav>
</header>
