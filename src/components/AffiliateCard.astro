---
import { offersFor, type Placement } from "../lib/affiliates.ts";

interface Props {
  placement: Placement;
}
const { placement } = Astro.props;
const offers = offersFor(placement);
---

{
  offers.length > 0 && (
    <div class="mt-6 space-y-4">
      {offers.map((o) => (
        <aside class="rounded-2xl border border-brand-200 bg-brand-50 p-5">
          <div class="flex items-start justify-between gap-3">
            <h3 class="font-bold text-slate-900">{o.headline}</h3>
            {o.badge && (
              <span class="shrink-0 rounded-full bg-brand-600 px-2.5 py-1 text-xs font-semibold text-white">
                {o.badge}
              </span>
            )}
          </div>
          <p class="mt-2 text-sm leading-relaxed text-slate-700">{o.body}</p>
          <a
            href={o.url}
            rel="sponsored nofollow noopener"
            target="_blank"
            class="btn mt-4"
          >
            {o.cta}
          </a>
          <p class="mt-2 text-[11px] text-slate-500">
            Partner offer — we may earn a commission. This is not a recommendation
            for your situation.
          </p>
        </aside>
      ))}
    </div>
  )
}
