---
import Layout from "../components/Layout.astro";
import { SITE } from "../config.ts";
---

<Layout title="Terms of Use" description="The terms governing your use of PennyGrove." path="/terms">
  <div class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">Terms of Use</h1>
    <p class="mt-2 text-sm text-slate-400">Last updated: June 2026</p>
    <div class="prose-money mt-6">
      <h2>Acceptance</h2>
      <p>
        By using {SITE.name}, you agree to these terms. If you don't agree, please
        don't use the site.
      </p>

      <h2>Educational use only</h2>
      <p>
        All calculators, guides and other content are provided for general
        educational and informational purposes. They do not constitute financial,
        investment, tax, accounting, or legal advice, and no
        advisor-client relationship is created by your use of the site.
      </p>

      <h2>No warranty; estimates only</h2>
      <p>
        Calculator results are estimates based on the inputs you provide and the
        assumptions described on each page. We strive for accuracy but make no
        warranty that results are error-free or suitable for your situation. Real
        rates, returns, taxes and fees vary. Use the outputs as a starting point,
        not a guarantee.
      </p>

      <h2>Limitation of liability</h2>
      <p>
        To the fullest extent permitted by law, {SITE.name} and its operators are
        not liable for any loss or damage arising from your use of, or reliance on,
        this site or its content. You are responsible for your own financial
        decisions.
      </p>

      <h2>Third-party links</h2>
      <p>
        The site contains links to third-party websites, including advertising and
        affiliate partners. We are not responsible for the content, products, or
        practices of those sites.
      </p>

      <h2>Changes</h2>
      <p>
        We may update these terms or the site's content at any time. Continued use
        after changes means you accept the revised terms.
      </p>

      <p class="text-sm text-slate-500">
        Questions? Contact <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
      </p>
    </div>
  </div>
</Layout>
