---
import Layout from "../components/Layout.astro";
import { CALCULATORS } from "../lib/catalog.ts";
---

<Layout title="Page not found" description="That page doesn't exist." path="/404" noindex>
  <div class="mx-auto max-w-2xl px-4 py-24 text-center">
    <div class="text-6xl font-extrabold text-brand-600">404</div>
    <h1 class="mt-3 text-2xl font-bold text-slate-900">We couldn't find that page</h1>
    <p class="mt-2 text-slate-600">But here's something useful instead — pick a calculator:</p>
    <div class="mt-6 flex flex-wrap justify-center gap-2">
      {CALCULATORS.map((c) => (
        <a href={`/calculators/${c.slug}`} class="rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:border-brand-300 hover:text-brand-700">
          {c.short}
        </a>
      ))}
    </div>
    <a href="/" class="btn mt-8">Back home</a>
  </div>
</Layout>
