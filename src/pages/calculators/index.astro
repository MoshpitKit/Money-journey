---
import Layout from "../../components/Layout.astro";
import { CALCULATORS } from "../../lib/catalog.ts";
---

<Layout
  title="All Money Calculators"
  description="Free personal-finance calculators: compound interest, mortgage, debt payoff, retirement, savings goals and budgeting. Accurate, instant, no sign-up."
  path="/calculators"
>
  <div class="mx-auto max-w-6xl px-4 py-12">
    <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
      All calculators
    </h1>
    <p class="mt-3 max-w-2xl text-lg text-slate-600">
      Pick a tool below. Each one is free, runs entirely in your browser, and
      explains what your result actually means.
    </p>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {CALCULATORS.map((c) => (
        <a href={`/calculators/${c.slug}`} class="card group transition hover:-translate-y-1 hover:border-brand-300 hover:shadow-md">
          <div class="grid h-11 w-11 place-items-center rounded-xl bg-brand-50 text-brand-600">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d={c.icon} />
            </svg>
          </div>
          <h2 class="mt-4 text-lg font-bold text-slate-900 group-hover:text-brand-700">{c.title}</h2>
          <p class="mt-1.5 text-sm text-slate-500">{c.blurb}</p>
        </a>
      ))}
    </div>
  </div>
</Layout>
